## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.

# User-specific files
*.suo
*.user
*.sln.docstates

# Build results
[Dd]ebug/
[Rr]elease/
x64/
x86/
build/
bld/
[Bb]in/
[Oo]bj/

# Visual Studio cache/options
.vs/
*.userprefs

# Rider
.idea/

# VS Code
.vscode/

# Environment variables - NEVER commit credentials!
.env

# Generated output
DATA_DICTIONARY.md

# NuGet Packages
*.nupkg
*.snupkg
**/packages/*
!**/packages/build/

# Mac
.DS_Store
